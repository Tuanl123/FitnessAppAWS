# ─── Shared ───
ENVIRONMENT=local
JWT_SECRET=dev-secret-key-change-in-production

# ─── Postgres ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpass
POSTGRES_DB=postgres

# ─── User Service ───
USER_DB_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/user_db

# ─── Metrics / Ingestion Service ───
SQS_ENDPOINT_URL=http://localhost:4566
SQS_QUEUE_NAME=analytics-queue
ANALYTICS_DB_URL=postgresql://postgres:devpass@localhost:5432/analytics_db

# ─── Analytics Lambda / Worker ───
SNS_TOPIC_ARN=
AWS_REGION=us-east-1

# ─── Frontend (Vite) ───
VITE_API_BASE_URL=
